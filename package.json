{
	"name": "meridian",
	"private": true,
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"packageManager": "pnpm@9.15.2",
	"scripts": {
		"prepare": "husky",
		"setup": "node scripts/setup-env.js",
		"dev": "pnpm --filter @meridian/api --filter @meridian/chat -r --parallel dev",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "pnpm -r run typecheck",
		"test": "pnpm -r run test",
		"build": "pnpm -r run build"
	},
	"lint-staged": {
		"*.{ts,tsx,json,mjs}": "biome check --write --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"typescript": "^5.9.3"
	}
}
