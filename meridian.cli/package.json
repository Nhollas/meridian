{
	"name": "@comparethemarket/meridian-cli",
	"version": "0.5.0",
	"description": "CLI for Compare the Market's comparison capabilities, including authentication, products, proposal requests, proposals, and results",
	"type": "module",
	"files": [
		"dist/meridian.js",
		"README.md"
	],
	"bin": {
		"meridian": "dist/meridian.js"
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "tsx --env-file=.env src/dev.ts",
		"build": "node scripts/bundle.js",
		"typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"release": "semantic-release",
		"release:dry-run": "semantic-release --dry-run",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{ts,json}": "biome check --write --no-errors-on-unmatched"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@semantic-release/changelog": "^6.0.3",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/npm": "^12.0.2",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@types/node": "^25.3.3",
		"@vitest/coverage-v8": "^4.0.18",
		"esbuild": "^0.27.3",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.2",
		"msw": "^2.12.10",
		"semantic-release": "^24.2.9",
		"tsx": "^4.19.0",
		"typescript": "^5.6.0",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"commander": "^14.0.3",
		"undici": "^7.16.0",
		"zod": "^4.3.6"
	}
}
