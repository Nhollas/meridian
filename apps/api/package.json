{
	"name": "@meridian/api",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch --env-file=.env src/server.ts",
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --config vitest.config.ts",
		"test:unit": "vitest run --config vitest.config.ts --project unit",
		"test:unit:watch": "vitest --config vitest.config.ts --project unit",
		"test:integration": "vitest run --config vitest.config.ts --project integration",
		"test:integration:watch": "vitest --config vitest.config.ts --project integration",
		"build:sandbox": "docker build -f Dockerfile.sandbox -t meridian-chat-sandbox:local ../.."
	},
	"dependencies": {
		"@meridian/contracts": "workspace:*",
		"@hono/node-server": "^1.19.11",
		"@langchain/core": "^1.1.31",
		"@langchain/langgraph": "^1.2.1",
		"@langchain/openai": "^1.2.12",
		"hono": "^4.12.7",
		"langchain": "^1.2.30",
		"openai": "^6.27.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.4.0",
		"tsx": "^4.19.0",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.0.18"
	}
}
