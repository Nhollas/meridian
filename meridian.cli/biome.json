{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noBannedTypes": "off",
				"useLiteralKeys": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"files": {
		"includes": [
			"**",
			"!dist",
			"!node_modules",
			"!**/dist",
			"!**/node_modules",
			"!coverage",
			"!gl-*.json"
		]
	}
}
