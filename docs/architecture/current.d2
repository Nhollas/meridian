direction: right

clients: "" {
  direction: down
  grid-gap: 48
  style.stroke-width: 0
  style.fill: transparent

  chat: Web {
    icon: https://cdn.simpleicons.org/googlechrome
  }
}

core: "" {
  direction: down
  grid-gap: 140
  style.stroke-width: 0
  style.fill: transparent

  api: Hono API Server {
    grid-columns: 1
    grid-gap: 16
    style.font-size: 16
    style.bold: true

    hono-icon: "" {
      icon: https://cdn.simpleicons.org/hono
      shape: image
      width: 64
      height: 64
    }

    spacer: "" {
      width: 200
      height: 1
      style.opacity: 0
      style.stroke-width: 0
    }

    agent: LangGraph Agent {
      icon: https://cdn.simpleicons.org/langchain
    }
  }

  service-gap: "" {
    width: 1
    height: 120
    style.opacity: 0
    style.stroke-width: 0
  }

  sandbox: Docker Sandbox {
    grid-columns: 1
    grid-gap: 16
    style.font-size: 16
    style.bold: true

    docker-icon: "" {
      icon: https://cdn.simpleicons.org/docker
      shape: image
      width: 64
      height: 64
    }

    spacer: "" {
      width: 200
      height: 1
      style.opacity: 0
      style.stroke-width: 0
    }

    cli: CLI {
      icon: https://cdn.simpleicons.org/gnubash
    }
  }
}

external: "" {
  direction: down
  grid-gap: 56
  style.stroke-width: 0
  style.fill: transparent

  openai: OpenAI {
    icon: https://cdn.simpleicons.org/openai
  }

  identity: "" {
    direction: down
    grid-gap: 28
    style.stroke-width: 0
    style.fill: transparent

    user: User {
      icon: https://icons.terrastruct.com/essentials%2F359-users.svg
    }

    keycloak: Keycloak {
      icon: https://cdn.simpleicons.org/letsencrypt
    }
  }
}

clients.chat <-> core.api: NDJSON
core.api -> external.openai: inference {
  style.stroke-dash: 3
}
core.api.agent -> core.sandbox: exec commands

core.sandbox -> external.identity.user: OAuth 2.0 device flow login URL {
  style.stroke-dash: 3
}
external.identity.user -> external.identity.keycloak: authenticates {
  style.stroke-dash: 3
}
